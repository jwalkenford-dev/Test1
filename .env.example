# Gmail SMTP credentials
# Use an App Password, NOT your Google account password.
# Generate at: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on your Google account)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Twilio SMS credentials
# Sign up at https://www.twilio.com — free trial gives you a phone number
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567

# Public base URL of this app — used in reminder email links
# No trailing slash
BASE_URL=http://localhost:5000

# Flask settings
FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=false

# Optional: custom path for the SQLite database (default: bookings.db)
# DB_PATH=bookings.db
